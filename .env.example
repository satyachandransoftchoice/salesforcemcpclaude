# ─── Salesforce MCP Server – Environment Configuration ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Active Environment ──────────────────────────────────────────────────────────
# "sandbox" or "production" – can also be toggled at runtime via sf_toggle_environment tool
SF_ENVIRONMENT=sandbox

# ── Server Transport ────────────────────────────────────────────────────────────
# "stdio"  → for local Claude Desktop / Claude Code (default)
# "http"   → for remote / org deployment via HTTP
TRANSPORT=stdio
PORT=3000

# ── Salesforce API ──────────────────────────────────────────────────────────────
SF_API_VERSION=v59.0

# ── Sandbox Environment ─────────────────────────────────────────────────────────
SF_SANDBOX_URL=https://test.salesforce.com
# If your sandbox has a custom domain, set it here instead:
# SF_SANDBOX_URL=https://yourorg--sandboxname.sandbox.my.salesforce.com

# Connected App credentials for sandbox
SF_SANDBOX_CLIENT_ID=your_sandbox_connected_app_client_id
SF_SANDBOX_CLIENT_SECRET=your_sandbox_connected_app_client_secret

# ── Production Environment ──────────────────────────────────────────────────────
SF_PROD_URL=https://login.salesforce.com
# If your org has a custom domain:
# SF_PROD_URL=https://yourorg.my.salesforce.com

# Connected App credentials for production
SF_PROD_CLIENT_ID=your_prod_connected_app_client_id
SF_PROD_CLIENT_SECRET=your_prod_connected_app_client_secret

# ── Shared (if using same connected app for both) ───────────────────────────────
# SF_CLIENT_ID=your_connected_app_client_id
# SF_CLIENT_SECRET=your_connected_app_client_secret

# ── OAuth Redirect URI ──────────────────────────────────────────────────────────
SF_REDIRECT_URI=https://login.salesforce.com/services/oauth2/success
