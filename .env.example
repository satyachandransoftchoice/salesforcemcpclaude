# ─── Salesforce MCP Server – Environment Configuration ───────────────────────

# ── Public URL (REQUIRED for OAuth) ─────────────────────────────────────────
# The publicly-accessible URL where this server is hosted.
# Set in Railway/Azure to the deployment URL.
PUBLIC_BASE_URL=https://your-deployment.up.railway.app

# ── Active Salesforce Environment ───────────────────────────────────────────
# "sandbox" or "production" – togglable at runtime via sf_toggle_environment
SF_ENVIRONMENT=sandbox

# ── Transport ────────────────────────────────────────────────────────────────
# "http" for deployment (default), "stdio" for local Claude Desktop
TRANSPORT=http
PORT=3000

# ── Salesforce API ──────────────────────────────────────────────────────────
SF_API_VERSION=v59.0

# ── Sandbox Connected App ───────────────────────────────────────────────────
SF_SANDBOX_URL=https://test.salesforce.com
SF_SANDBOX_CLIENT_ID=your_sandbox_connected_app_consumer_key
SF_SANDBOX_CLIENT_SECRET=your_sandbox_connected_app_consumer_secret

# ── Production Connected App ────────────────────────────────────────────────
SF_PROD_URL=https://login.salesforce.com
SF_PROD_CLIENT_ID=your_prod_connected_app_consumer_key
SF_PROD_CLIENT_SECRET=your_prod_connected_app_consumer_secret

# ── Callback URL configured in your Salesforce Connected App ────────────────
# Must be:  {PUBLIC_BASE_URL}/oauth/callback
