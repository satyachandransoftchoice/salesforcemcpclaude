{
  "name": "salesforce-mcp-server",
  "version": "1.0.0",
  "description": "Salesforce MCP Server for Claude with full OAuth - read-only access to all objects + Case creation, with sandbox/production toggle",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.2",
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5",
    "tsx": "^4.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
